# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# Mistral AI: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# AI provider to use: 'mistral' (default) or 'gemini'
OPERATOR_PROVIDER=mistral

# Mistral model override (default mistral-medium-latest; the free tier also
# allows mistral-large-latest and mistral-small-latest). Optional.
# OPERATOR_MISTRAL_MODEL=mistral-medium-latest
# Fallback used when the primary model is rate-limited (set empty to disable).
# OPERATOR_MISTRAL_FALLBACK=mistral-small-latest

# Global hotkey that summons the overlay bar (pynput syntax). Optional.
# OPERATOR_HOTKEY=<ctrl>+<alt>+o

# Voice input (requires: pip install -r requirements-voice.txt). Optional.
# OPERATOR_VOICE_HOTKEY=<ctrl>+<alt>+v
# OPERATOR_WHISPER_MODEL=base

# Localhost port for the Chrome extension bridge. Must match BRIDGE_URL in
# extension/background.js if changed. Optional.
# OPERATOR_BROWSER_PORT=8377

# Client-side rate limiting: min seconds between LLM API calls, and how many
# times to retry a 429 with backoff. Defaults suit Mistral's free tier; on a
# paid tier you can lower the interval (e.g. 0.2). Optional.
# OPERATOR_LLM_INTERVAL=1.1
# OPERATOR_LLM_MAX_RETRIES=4
